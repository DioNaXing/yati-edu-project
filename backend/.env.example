# 亚体教务系统 — 环境变量模板
# 复制为 .env 并填入真实值
# cp .env.example .env

# ── 数据库 ────────────────────────
DATABASE_URL=sqlite:///data/yati_edu.db

# ── JWT 密钥 ──────────────────────
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── One API（AI 模型网关）─────────
ONE_API_BASE_URL=http://localhost:3001/v1
ONE_API_TOKEN=your-one-api-token

# ── 企业微信 ──────────────────────
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_APP_SECRET=your-app-secret
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# ── 服务器 ────────────────────────
HOST=0.0.0.0
PORT=8000

# ── 可选：阿里云短信 ──────────────
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
