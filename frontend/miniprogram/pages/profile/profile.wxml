<view class="container">
  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" />
    <text class="nickname">{{userInfo.name || '家长'}}</text>
    <text class="phone">{{userInfo.phone || '未绑定手机'}}</text>
  </view>

  <view class="section">
    <view class="menu-item" bindtap="goKids">
      <text class="menu-icon">👶</text>
      <text class="menu-text">宝贝管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPayments">
      <text class="menu-icon">💰</text>
      <text class="menu-text">缴费记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goContact">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section">
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">🏢</text>
      <text class="menu-text">关于亚体</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
