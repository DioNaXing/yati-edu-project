.container {
  padding-bottom: 40rpx;
}

.banner {
  width: 100%;
  height: 360rpx;
  position: relative;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
}

.banner-overlay {
  position: absolute;
  left: 40rpx;
  bottom: 40rpx;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.banner-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
  display: block;
}

.quick-actions {
  display: flex;
  background: #fff;
  padding: 30rpx;
  margin-top: -30rpx;
  border-radius: 20rpx 20rpx 0 0;
  position: relative;
  z-index: 1;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.class-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.class-time {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
  width: 120rpx;
}

.class-info {
  flex: 1;
}

.class-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.class-coach {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.class-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.class-status.upcoming {
  background: #FFF3E0;
  color: #FF6B35;
}

.class-status.ongoing {
  background: #E8F5E9;
  color: #4CAF50;
}

.balance-card {
  display: flex;
  align-items: baseline;
  padding: 20rpx 0;
}

.balance-num {
  font-size: 72rpx;
  font-weight: bold;
  color: #FF6B35;
}

.balance-unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
  margin-right: 40rpx;
}

.btn-recharge {
  background: #FF6B35;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  line-height: 1.2;
}

.news-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
}

.news-title {
  font-size: 28rpx;
  color: #333;
}

.news-date {
  font-size: 24rpx;
  color: #ccc;
}
